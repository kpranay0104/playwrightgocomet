{
  "name": "ui-test-automation-framework",
  "version": "1.0.0",
  "description": "Reusable UI automation framework (Playwright + TypeScript) for login and search workflow testing, integrated with CI/CD.",
  "private": true,
  "scripts": {
    "bdd:gen": "bddgen --config=playwright.config.ts",
    "test": "npm run bdd:gen && playwright test --workers=1",
    "test:headed": "npm run bdd:gen && playwright test --headed --workers=1",
    "test:debug": "npm run bdd:gen && playwright test --debug --workers=1",
    "report": "playwright show-report playwright-report-bdd",
    "install:browsers": "playwright install --with-deps chromium"
  },
  "devDependencies": {
    "@playwright/test": "1.41.2",
    "@types/node": "^20.14.0",
    "playwright": "1.41.2",
    "playwright-bdd": "^7.4.0",
    "typescript": "^5.5.0"
  }
}
