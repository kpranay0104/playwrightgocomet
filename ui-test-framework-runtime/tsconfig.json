{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "lib": ["ES2021", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@framework/*": ["framework/*"],
      "@tests/*": ["tests/*"]
    }
  },
  "include": ["framework/**/*.ts", "tests/**/*.ts", "features/**/*.ts", "playwright.config.ts", "playwright.config.bdd.ts"],
  "exclude": ["node_modules", "playwright-report", "test-results"]
}
