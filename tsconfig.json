{
  "compilerOptions": {
    "target": "ES2021",
    "module": "nodenext",
    "lib": ["ES2021", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "nodenext",
    "baseUrl": ".",
    "paths": {
      "@helpers/*": ["helpers/*"]
    }
  },
  "include": [
    "helpers/**/*.ts",
    "features/**/*.feature",
    "features/**/*.ts",
    "step-definitions/**/*.ts",
    "playwright.config.ts"
  ],
  "exclude": ["node_modules", "playwright-report", "test-results"]
}
